rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── User profiles ───────────────────────────────────────────────────────
    // user_profiles/{uid} — sadece kendi kullanıcısı okuyabilir/yazabilir
    match /user_profiles/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ─── Users (premium status, backend-managed) ─────────────────────────────
    // users/{uid} — read-only for clients; only Admin SDK writes
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; // Only Admin SDK writes
    }

    // ─── Analysis history ─────────────────────────────────────────────────────
    // users/{uid}/analyses/{docId}
    match /users/{uid}/analyses/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ─── Daily quota usage ────────────────────────────────────────────────────
    // dailyUsage/{uid} — read-only for clients; only backend (Admin SDK) can write
    match /dailyUsage/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }
    match /dailyUsage/{uid}/days/{date} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // ─── Pain logs ────────────────────────────────────────────────────────────
    // users/{uid}/painLogs/{date}
    match /users/{uid}/painLogs/{date} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ─── Physiotherapists ────────────────────────────────────────────────────
    // physiotherapists/{uid} — PT reads/writes own profile; anyone reads approved
    match /physiotherapists/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ─── Conversations ────────────────────────────────────────────────────────
    // conversations/{convId} — participants can read/write
    match /conversations/{convId} {
      allow read: if request.auth != null &&
        resource != null &&
        (request.auth.uid == resource.data.userId ||
         request.auth.uid == resource.data.ptId);
      allow update, delete: if request.auth != null &&
        resource != null &&
        (request.auth.uid == resource.data.userId ||
         request.auth.uid == resource.data.ptId);
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.userId;

      match /messages/{msgId} {
        allow read, create: if request.auth != null &&
          (request.auth.uid == get(/databases/$(database)/documents/conversations/$(convId)).data.userId ||
           request.auth.uid == get(/databases/$(database)/documents/conversations/$(convId)).data.ptId);
      }
    }

    // ─── Weekly program ───────────────────────────────────────────────────────
    // users/{uid}/program/current
    match /users/{uid}/program/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ─── Varsayılan: her şeyi reddet ──────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
