{
  "permissions": {
    "allow": [
      "Bash(node server.js)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(sudo rm*)",
      "Bash(chmod 777*)",
      "Bash(curl * | bash)",
      "Bash(wget * | bash)",
      "Bash(ssh*)",
      "Bash(> /dev/*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|TodoWrite",
        "hooks": [
          {
            "type": "command",
            "command": "npx tdd-guard@latest"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx tdd-guard@latest"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash C:/Users/KULLANICI/Desktop/fizyoterapi/.claude/hooks/dart_format.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash C:/Users/KULLANICI/Desktop/fizyoterapi/.claude/hooks/flutter_analyze.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash C:/Users/KULLANICI/Desktop/fizyoterapi/.claude/hooks/pub_get.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash C:/Users/KULLANICI/Desktop/fizyoterapi/.claude/hooks/backend_restart.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash C:/Users/KULLANICI/Desktop/fizyoterapi/.claude/hooks/chat_check.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash C:/Users/KULLANICI/Desktop/fizyoterapi/.claude/hooks/notify.sh"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Compaction tamamlandı. CLAUDE.md dosyasını yeniden oku ve kuralları uygula.'"
          }
        ]
      }
    ]
  }
}
